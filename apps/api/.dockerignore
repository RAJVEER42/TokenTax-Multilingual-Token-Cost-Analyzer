# TokenTax API — Docker Build Exclusions
# Keeps build context small and prevents dev files in production image

# Version control
.git
.gitignore

# Python caches
__pycache__
*.py[cod]
*$py.class
.mypy_cache
.ruff_cache
.pytest_cache
htmlcov
.coverage
*.cover
coverage.xml

# Virtual environments
.venv
venv
env

# Dev dependencies & config
requirements-dev.txt
pyproject.toml

# IDE
.vscode
.idea
*.swp
*.swo

# Docker files (prevent recursive copy)
Dockerfile*
.dockerignore
docker-compose*

# Documentation
*.md
docs/

# Test files (not needed in production image)
tests/

# Alembic migration cache
migrations/versions/__pycache__

# OS files
.DS_Store
Thumbs.db
