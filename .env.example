# ==========================
# TokenTax E# ── CORS ─────────────────────────────────────────────
CORS_ORIGINS_STR=http://localhost:3000,http://127.0.0.1:3000ironment Configuration
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ==========================

# ── Application ──────────────────────────────────────────
APP_ENV=development
APP_NAME=TokenTax
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# ── API ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ── Security ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-32-byte-hex-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tokentax
POSTGRES_USER=tokentax
POSTGRES_PASSWORD=tokentax_dev_password
DATABASE_URL=postgresql+asyncpg://tokentax:tokentax_dev_password@postgres:5432/tokentax

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
REDIS_TTL_SECONDS=3600

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Worker ───────────────────────────────────────────────
WORKER_CONCURRENCY=4
BATCH_MAX_SIZE=1000

# ── Tokenizer ────────────────────────────────────────────
TOKENIZER_CACHE_TTL=86400
DEFAULT_TOKENIZER=tiktoken

# ── Pricing ──────────────────────────────────────────────
PRICING_SNAPSHOT_DIR=data/pricing_snapshots
