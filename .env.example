# TokenTax Environment Configuration
# Copy this file to .env and fill in values for your environment
# NEVER commit .env to version control
# For detailed documentation, see ENV_VARIABLES.md

# ==========================
# ── APPLICATION ──────────────────────────────────────────
# ==========================
APP_ENV=development
APP_NAME=TokenTax
APP_VERSION=0.9.0
DEBUG=true
LOG_LEVEL=INFO

# ==========================
# ── API ───────────────────────────────────────────────────
# ==========================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ==========================
# ── SECURITY ──────────────────────────────────────────────
# ==========================
# ⚠️ CRITICAL: Generate with `openssl rand -hex 32`
# NEVER use the example value in production
SECRET_KEY=dev-only-change-in-production-32-byte-hex-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================
# ── DATABASE (PostgreSQL) ─────────────────────────────────
# ==========================
# Format: postgresql+asyncpg://user:password@host:port/database
# Local: postgresql+asyncpg://tokentax:tokentax_dev_password@localhost:5432/tokentax
# Docker: postgresql+asyncpg://postgres:postgres@db:5432/tokentax
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/tokentax

# PostgreSQL connection parameters
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=tokentax
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ==========================
# ── REDIS (Caching) ───────────────────────────────────────
# ==========================
# Format: redis://:password@host:port/db
# Local: redis://localhost:6379/0
# Docker: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0
REDIS_TTL_SECONDS=3600

# ==========================
# ── CORS (Cross-Origin) ───────────────────────────────────
# ==========================
# Comma-separated list of allowed frontend origins
# Local dev: http://localhost:5173,http://localhost:3000
# Production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS_STR=http://localhost:5173,http://localhost:3000

# ==========================
# ── TOKENIZER ─────────────────────────────────────────────
# ==========================
DEFAULT_TOKENIZER=tiktoken
TOKENIZER_CACHE_TTL=86400
TOKENIZERS_PARALLELISM=false
BATCH_MAX_SIZE=1000
WORKER_CONCURRENCY=4

# ==========================
# ── PRICING & DATA ────────────────────────────────────────
# ==========================
PRICING_SNAPSHOT_DIR=data/pricing_snapshots

# ==========================
# ── FRONTEND (Vite) ───────────────────────────────────────
# ==========================
# Backend API URL that frontend will call
VITE_API_URL=http://localhost:8000/api/v1

# Vite dev server proxy target (only used in dev mode)
VITE_PROXY_TARGET=http://api:8000
DEFAULT_TOKENIZER=tiktoken

# ── Pricing ──────────────────────────────────────────────
PRICING_SNAPSHOT_DIR=data/pricing_snapshots
