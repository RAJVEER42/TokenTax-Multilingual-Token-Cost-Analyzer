# ============================================================
# TokenTax — Production Environment Variables
# ============================================================
#
# Copy to .env.production and fill in real values.
# NEVER commit this file with real secrets.
#
# Usage:
#   cp .env.production.example .env.production
#   # Edit values...
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
# ============================================================

# ── Application ──────────────────────────────────────────
APP_ENV=production
DOMAIN=tokentax.io
ENVIRONMENT=production

# ── Security ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ── Database ─────────────────────────────────────────────
# Production: use managed PostgreSQL (RDS, Cloud SQL, etc.)
DATABASE_URL=postgresql+asyncpg://tokentax:STRONG_PASSWORD@db:5432/tokentax
POSTGRES_USER=tokentax
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=tokentax
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────
# Production: use managed Redis (ElastiCache, Memorystore, etc.)
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS_STR=https://tokentax.io,https://www.tokentax.io

# ── Monitoring ───────────────────────────────────────────
# Get DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=

# ── Frontend ─────────────────────────────────────────────
VITE_API_URL=/api/v1

# ── Ports (override defaults if needed) ──────────────────
API_PORT=8000
WEB_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ── Grafana ──────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD
GRAFANA_ROOT_URL=https://grafana.tokentax.io
